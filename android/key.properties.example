# Release signing for Google Play — copy this file to `key.properties` and fill
# in real values, or run the commands below. `key.properties`, `*.jks`, and
# `*.keystore` are git-ignored; never commit them.
#
# 1. Generate an upload keystore (once):
#
#      keytool -genkey -v -keystore ~/watbal-upload.jks \
#        -keyalg RSA -keysize 2048 -validity 10000 -alias upload
#
# 2. Copy this file:  cp key.properties.example key.properties
# 3. Point storeFile at the .jks you generated and fill in the passwords.
# 4. Build a release bundle:  flutter build appbundle --release
#
# With Google Play App Signing enabled (recommended), this key is your *upload*
# key; Google holds the real app-signing key. If key.properties is absent the
# build falls back to debug signing so `flutter run` still works.

storePassword=your-keystore-password
keyPassword=your-key-password
keyAlias=upload
storeFile=/absolute/path/to/watbal-upload.jks
